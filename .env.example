# Environment Variables for ACity Connect Backend
# Copy this file to .env and fill in the real values.
# NEVER commit the .env file to GitHub (it contains secrets).

# The full PostgreSQL connection string from Render.com
# Example: postgres://user:password@host:5432/dbname
DATABASE_URL=your_postgresql_url_here

# A long random secret string used to sign JWT tokens
# You can generate one at: https://randomkeygen.com
JWT_SECRET=change_this_to_a_long_random_string

# Set to 'production' when deploying on Render.com
NODE_ENV=development
